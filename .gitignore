# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment & secrets ──────────────────────────────────────────────────────
.env
.env.*
secrets.json
.streamlit/secrets.toml

# ── Local cache & generated indexes ───────────────────────────────────────────
# The local FAISS index is built on first run via build_local_index.py.
# These files are large and machine-specific — do not commit them.
cache/
*.faiss
*.index

# ── Model weights ─────────────────────────────────────────────────────────────
*.pt
*.pth
*.ckpt

# ── HuggingFace / Transformers cache ──────────────────────────────────────────
.cache/
models/
transformers_cache/
huggingface_cache/

# ── Large data files ───────────────────────────────────────────────────────────
# Product images should not be committed; they are pulled from HuggingFace Hub.
img/images/
img/myntradataset/
img/images_backup/
img/styles_backup.csv

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs & temporary files ─────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/
watch_*

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db

# ── IDE & editors ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Coverage & testing ────────────────────────────────────────────────────────
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ── Documentation builds ──────────────────────────────────────────────────────
docs/_build/
site/
